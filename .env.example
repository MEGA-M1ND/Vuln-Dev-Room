# ---------------------------------------------------------------------------
# Dev Room — Stage 1 environment
# Copy to `.env` and fill in. Never commit `.env`.
# ---------------------------------------------------------------------------

# PostgreSQL connection string (source of truth for all durable state).
DATABASE_URL="postgresql://devroom:devroom@127.0.0.1:5432/devroom?schema=public"

# NextAuth / Auth.js — required. Generate with: `openssl rand -base64 32`
AUTH_SECRET="replace-with-a-long-random-string"

# Base URL of the app (used by Auth.js).
NEXTAUTH_URL="http://localhost:3000"

# Enables the development-only "sign in as seeded user" switcher.
# MUST be unset/false in production. The Credentials provider is only
# registered when this is "true" AND NODE_ENV !== "production".
DEV_AUTH_ENABLED="true"

# ---------------------------------------------------------------------------
# Liveblocks — realtime presence + comment threads.
# Free tier is sufficient for Stage 1: https://liveblocks.io/dashboard
# The board (Postgres) works without these, but presence/comments need them.
# ---------------------------------------------------------------------------
LIVEBLOCKS_SECRET_KEY=""
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=""

# ---------------------------------------------------------------------------
# Playwright e2e (optional)
# ---------------------------------------------------------------------------
# E2E_BASE_URL="http://localhost:3000"
