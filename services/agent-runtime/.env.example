# ---------------------------------------------------------------------------
# Dev Room agent runtime — Stage 2 (host-only configuration)
# Copy to `.env`. These values live ONLY on the agent-runtime host and are
# never sent to browsers.
# ---------------------------------------------------------------------------

# Shared internal service token. MUST match the web app's
# DEVROOM_AGENT_SERVICE_TOKEN. Requests without it are rejected.
DEVROOM_AGENT_SERVICE_TOKEN="change-me-to-a-long-random-string"

# Postgres — the SAME database the web app/Prisma uses. The runtime only writes
# to the Stage 2 run tables (AgentRun / RunArtifact / RunEvent).
DATABASE_URL="postgresql://devroom:devroom@127.0.0.1:5432/devroom"

# Optional: separate DB URL for LangGraph checkpoints. Defaults to DATABASE_URL,
# pinned to the dedicated `langgraph` schema either way.
# DEVROOM_LANGGRAPH_DATABASE_URL=""

# Stage 3: the Next.js app base URL. The runtime posts run status/event changes
# to its internal callback so the web app can broadcast realtime updates to the
# room over Liveblocks. Leave empty to disable realtime pings (polling still
# works). Uses DEVROOM_AGENT_SERVICE_TOKEN for auth.
DEVROOM_WEB_CALLBACK_URL="http://127.0.0.1:3000"

# Sandbox image. Normal environments: build docker/sandbox.Dockerfile and use
# `devroom-sandbox:latest`. Restricted environments: build the offline image
# with docker/build-offline-sandbox.sh and use `devroom-sandbox:local`.
DEVROOM_SANDBOX_IMAGE="python:3.11-slim"

# Sandbox resource limits.
DEVROOM_SANDBOX_MEMORY="512m"
DEVROOM_SANDBOX_CPUS="1.0"
DEVROOM_SANDBOX_PIDS_LIMIT="256"
DEVROOM_SANDBOX_TIMEOUT="120"

# Model provider. "fake" is deterministic and requires no key (used by tests and
# offline demos). "anthropic" requires ANTHROPIC_API_KEY.
DEVROOM_MODEL_PROVIDER="fake"
# DEVROOM_MODEL_NAME="claude-opus-4-8"
# ANTHROPIC_API_KEY=""

# Repository registry. `source_path` must be a valid Git repo ON THIS HOST. It
# is copied into a fresh sandbox per run and never modified. Unknown keys are
# rejected; browser requests never provide a path.
DEVROOM_REPOSITORIES_JSON='{
  "agentguard-demo": {
    "display_name": "AgentGuard demo repository",
    "source_path": "/absolute/path/to/agentguard-demo",
    "allowed_paths": ["backend/**", "tests/**"],
    "test_command": "python -m pytest -q",
    "language": "python"
  }
}'
